<Window x:Class="UIElementInspector.Windows.PieProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Progress"
        Width="140" Height="160"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        IsHitTestVisible="False">

    <!-- Semi-transparent rounded container -->
    <Border CornerRadius="12" Background="#CC222222" Padding="10" Margin="5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <StackPanel HorizontalAlignment="Center">
            <!-- Pie Chart Area -->
            <Grid Width="80" Height="80" HorizontalAlignment="Center">
                <!-- Background track circle -->
                <Ellipse Width="80" Height="80"
                         Stroke="#55FFFFFF" StrokeThickness="0"
                         Fill="#33FFFFFF"/>

                <!-- Pie progress arc (drawn in code-behind) -->
                <Path Name="pieArc" Fill="#1976D2" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- Inner circle overlay for donut effect -->
                <Ellipse Width="52" Height="52"
                         Fill="#CC222222"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- Percentage text in center -->
                <TextBlock Name="txtPercent" Text="0%"
                           Foreground="White" FontSize="16" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- Completion checkmark (hidden by default) -->
                <TextBlock Name="txtCheckmark" Text="&#x2714;"
                           Foreground="#4CAF50" FontSize="28" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </Grid>

            <!-- Step text -->
            <TextBlock Name="txtStep" Text=""
                       Foreground="#BBBBBB" FontSize="11"
                       HorizontalAlignment="Center" Margin="0,6,0,0"/>

            <!-- Status message -->
            <TextBlock Name="txtMessage" Text=""
                       Foreground="#999999" FontSize="9"
                       HorizontalAlignment="Center" Margin="0,2,0,0"
                       TextTrimming="CharacterEllipsis" MaxWidth="120"
                       TextAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
