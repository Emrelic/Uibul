<Window x:Class="UIElementInspector.CaptureNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Yakalama Adı"
        Width="450" Height="180"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Topmost="True"
        FocusManager.FocusedElement="{Binding ElementName=NameTextBox}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Yakalama için bir isim girin:"
                   FontSize="14" Margin="0,0,0,10"/>

        <TextBox Grid.Row="1" x:Name="NameTextBox"
                 FontSize="14" Padding="5,3"
                 MaxLength="100"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Tamam" Width="90" Height="30"
                    IsDefault="True" Click="OkButton_Click" Margin="0,0,10,0"/>
            <Button Content="İptal" Width="90" Height="30"
                    IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
